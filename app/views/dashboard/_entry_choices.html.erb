<%# app/views/dashboard/_entry_choices.html.erb %>
<%# Public homepage (logged-out root). Explains the app's purpose, features, and %>
<%# exactly how it uses Google Health data — viewable without logging in — and %>
<%# offers Log in / Sign up. "Log in" reveals the login modal in place. %>
<div data-controller="entry">
  <div data-entry-target="choices" class="min-h-screen bg-stone-900 text-gray-200">
    <div class="max-w-3xl mx-auto px-4 py-12">

      <%# Hero %>
      <header class="text-center">
        <h1 class="text-4xl md:text-5xl font-bold text-yellow-500 mb-3" style="font-family: 'Cinzel', serif;">
          Walk to Mordor
        </h1>
        <p class="text-gray-300 italic mb-6">"Not all those who wander are lost"</p>
        <p class="text-base md:text-lg text-gray-300 max-w-2xl mx-auto">
          Walk to Mordor is a collaborative fitness tracker that turns your daily steps into a shared
          3,659-mile journey across Middle-earth. From the Shire to the Grey Havens walk together with
          your friends, watch everyone move along the map, and celebrate the milestones you reach along the way.
        </p>
      </header>

      <%# Log in / Sign up %>
      <div class="mt-8 max-w-sm mx-auto bg-stone-800 rounded-lg shadow-2xl p-6 border-4 border-yellow-600">
        <button type="button" data-action="entry#showLogin"
                class="w-full py-3 px-4 mb-3 bg-yellow-600 hover:bg-yellow-700 text-stone-900 font-bold rounded-md transition-colors duration-200 cursor-pointer">
          Log in
        </button>
        <%= link_to "Sign up", sign_up_path,
            class: "block w-full py-3 px-4 border border-yellow-600 text-yellow-500 hover:bg-stone-700 font-bold rounded-md transition-colors duration-200 text-center" %>
        <p class="mt-4 text-xs text-gray-400 text-center">New here? Sign up to form your fellowship.</p>

        <div class="mt-6 flex justify-center">
          <a href="https://buymeacoffee.com/laurabrookx" target="_blank" rel="noopener"
             class="inline-flex items-center gap-2 py-2 px-4 rounded-md font-semibold text-black transition-opacity duration-200 hover:opacity-90"
             style="background-color: #FFDD00;">
            <span aria-hidden="true">☕</span> Buy me a coffee
          </a>
        </div>
      </div>

      <%# What you can do %>
      <section class="mt-12 grid gap-6 md:grid-cols-3">
        <div class="bg-stone-800 rounded-lg p-5 border border-stone-700">
          <h2 class="text-yellow-500 font-semibold mb-2">Walk together</h2>
          <p class="text-sm text-gray-300">Your group shares one path and one map, so you can see how far each friend has travelled and stay motivated together — even when you're far apart.</p>
        </div>
        <div class="bg-stone-800 rounded-lg p-5 border border-stone-700">
          <h2 class="text-yellow-500 font-semibold mb-2">Steps become miles</h2>
          <p class="text-sm text-gray-300">Log your daily steps by hand, or connect Google Health to sync them automatically. Steps convert to miles and move you along the journey.</p>
        </div>
        <div class="bg-stone-800 rounded-lg p-5 border border-stone-700">
          <h2 class="text-yellow-500 font-semibold mb-2">Reach milestones</h2>
          <p class="text-sm text-gray-300">Celebrate reaching iconic places like Rivendell, Moria, and Mount Doom, and track your pace toward the next stop on the map.</p>
        </div>
      </section>

      <%# How it works + exactly how Google Health data is used (verification requires
          the homepage to explain the purpose AND the use of the requested Google data). %>
      <section class="mt-10 bg-stone-800 rounded-lg p-5 border border-stone-700 text-sm text-gray-300 space-y-3">
        <h2 class="text-yellow-500 font-semibold">How it works &amp; how we use Google Health data</h2>
        <p>
          Each day you record your steps either by entering them manually, or by optionally connecting
          <strong>Google Health</strong>. Those steps are converted into miles (about 2,112 steps per mile)
          and used to advance your position along the journey and show it on your group's shared map.
        </p>
        <p>
          If you connect Google Health, the app requests <strong>read-only</strong> access to a single type
          of data your <strong>daily step count</strong>. That is the only Google data we request, and we
          use it for one purpose only: to calculate your progress along the journey. We do <strong>not</strong>
          sell it, use it for advertising, or share it beyond providing this feature.
        </p>
        <p>
          Connecting is entirely optional. You can <strong>disconnect at any time</strong> (which revokes our
          access with Google), and closing your account permanently deletes your data. Full details are in our
          <%= link_to "Privacy Policy", privacy_path, class: "text-yellow-500 underline hover:text-yellow-400" %>.
        </p>
      </section>

      <%# Footer: legal links %>
      <footer class="mt-10 pt-6 border-t border-stone-700 flex justify-center gap-3 text-xs text-gray-400">
        <%= link_to "Privacy Policy", privacy_path, class: "hover:text-yellow-500 transition-colors duration-200" %>
        <span aria-hidden="true">·</span>
        <%= link_to "Terms of Service", terms_path, class: "hover:text-yellow-500 transition-colors duration-200" %>
      </footer>
    </div>
  </div>

  <div data-entry-target="login" class="hidden">
    <%= render 'sessions/login_modal' %>
  </div>
</div>
