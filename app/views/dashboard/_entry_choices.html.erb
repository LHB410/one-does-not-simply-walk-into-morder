<%# app/views/dashboard/_entry_choices.html.erb %>
<%# Logged-out entry screen: choose to log in (reveals the existing login modal) %>
<%# or sign up (routes to the group sign-up page). %>
<div data-controller="entry">
  <div data-entry-target="choices"
       class="fixed inset-0 bg-stone-900 flex items-center justify-center z-40 p-4">
    <div class="bg-stone-800 rounded-lg shadow-2xl p-8 max-w-md w-full border-4 border-yellow-600 text-center">
      <h2 class="text-3xl font-bold text-yellow-500 mb-2" style="font-family: 'Cinzel', serif;">
        The Fellowship Tracker
      </h2>
      <p class="text-gray-300 text-sm italic mb-8">
        "Not all those who wander are lost"
      </p>

      <button type="button" data-action="entry#showLogin"
              class="w-full py-3 px-4 mb-3 bg-yellow-600 hover:bg-yellow-700 text-stone-900 font-bold rounded-md transition-colors duration-200 cursor-pointer">
        Log in
      </button>

      <%= link_to "Sign up", sign_up_path,
          class: "block w-full py-3 px-4 border border-yellow-600 text-yellow-500 hover:bg-stone-700 font-bold rounded-md transition-colors duration-200" %>

      <p class="mt-6 text-xs text-gray-400">New here? Sign up to form your fellowship.</p>

      <div class="mt-6 flex justify-center">
        <%# Static link styled like the Buy Me a Coffee button. The official widget
            script renders unreliably under Turbo navigation, so we use a plain
            link to the same page instead. %>
        <a href="https://buymeacoffee.com/laurabrookx" target="_blank" rel="noopener"
           class="inline-flex items-center gap-2 py-2 px-4 rounded-md font-semibold text-black transition-opacity duration-200 hover:opacity-90"
           style="background-color: #FFDD00;">
          <span aria-hidden="true">☕</span> Buy me a coffee
        </a>
      </div>

      <div class="mt-6 pt-4 border-t border-stone-700 flex justify-center gap-3 text-xs text-gray-400">
        <%= link_to "Privacy Policy", privacy_path, class: "hover:text-yellow-500 transition-colors duration-200" %>
        <span aria-hidden="true">·</span>
        <%= link_to "Terms of Service", terms_path, class: "hover:text-yellow-500 transition-colors duration-200" %>
      </div>
    </div>
  </div>

  <div data-entry-target="login" class="hidden">
    <%= render 'sessions/login_modal' %>
  </div>
</div>
