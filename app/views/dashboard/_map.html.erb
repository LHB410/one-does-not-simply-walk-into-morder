<!-- app/views/dashboard/_map.html.erb -->
<div class="relative w-full h-full"
     data-controller="map-zoom"
     data-map-zoom-initial-scale-value="1.0"
     data-map-zoom-center-x-value="50"
     data-map-zoom-center-y-value="50">
  <div data-map-zoom-target="content" class="absolute inset-0 origin-center">
    <!-- Background Map SVG -->
    <div class="absolute inset-0">
      <%= image_tag 'map_of_middle_earth.svg',
                    class: 'w-full h-full object-contain',
                    alt: 'Map of Middle Earth' %>
    </div>

    <!-- Overlay for Path and Tokens -->
    <svg class="absolute inset-0 w-full h-full pointer-events-none"
         viewBox="0 0 100 100"
         preserveAspectRatio="xMidYMid meet">

      <defs>
        <filter id="milestone-glow" x="-50%" y="-50%" width="200%" height="200%">
          <feGaussianBlur stdDeviation="0.5" result="blur"/>
          <feMerge>
            <feMergeNode in="blur"/>
            <feMergeNode in="SourceGraphic"/>
          </feMerge>
        </filter>
      </defs>

      <!-- The Journey Path -->
      <path id="journey-path"
            d="<%= path_coordinates(path) %>"
            stroke="#DC143C"
            stroke-width="0.5"
            fill="none"
            stroke-dasharray="1,1"
            opacity="1" />

      <!-- Milestone Markers -->
      <% reached_ids = reached_milestones_for(current_user, path) %>
      <% path&.milestones&.each do |milestone| %>
        <% reached = reached_ids.include?(milestone.id) && milestone.shop_url.present? %>
        <g class="milestone-marker" data-milestone-id="<%= milestone.id %>">
          <circle cx="<%= milestone.map_position_x %>"
                  cy="<%= milestone.map_position_y %>"
                  r="0.8"
                  fill="<%= reached ? '#FFD700' : '#8B0000' %>"
                  stroke="#FFD700"
                  stroke-width="<%= reached ? '0.5' : '0.3' %>"
                  <%= 'filter="url(#milestone-glow)"' if reached %> />
          <text x="<%= milestone.map_position_x %>"
                y="<%= milestone.map_position_y - 2 %>"
                font-size="0"
                fill="<%= reached ? '#FFD700' : '#2C1810' %>"
                font-weight="bold"
                text-anchor="middle">
            <%= milestone.name %>
          </text>
        </g>
      <% end %>

      <!-- User Tokens -->
      <% users.each_with_index do |user, index| %>
        <% path_user = user.current_position_on_path(path) %>
        <% position = calculate_token_position(path_user, path) %>
        <% is_current = current_user && user.id == current_user.id %>
        <% token_milestone = path_user&.current_milestone %>
        <% token_at_shop = is_current && token_milestone && reached_ids.include?(token_milestone.id) && token_milestone.shop_url.present? %>

        <g class="user-token"
           data-user-id="<%= user.id %>"
           <%= 'data-current-user="true"' if is_current %>
           data-turbo-permanent>

          <!-- Token Circle with User Color -->
          <circle cx="<%= position[:x] %>"
                  cy="<%= position[:y] + (index * 0.1) %>"
                  r="1"
                  fill="<%= user.token_color %>"
                  stroke="<%= token_at_shop ? '#FFD700' : 'white' %>"
                  stroke-width="<%= token_at_shop ? '0.4' : '0.2' %>"
                  class="transition-all duration-1000 ease-in-out" />

          <!-- User Initial -->
          <text x="<%= position[:x] %>"
                y="<%= position[:y] + (index * 0.1) + 0.5 %>"
                font-size="1.2"
                fill="white"
                font-weight="bold"
                text-anchor="middle">
            <%= user.name[0] %>
          </text>
        </g>
      <% end %>
    </svg>
  </div>
</div>
