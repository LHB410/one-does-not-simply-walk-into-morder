<% content_for(:title) { "Terms of Service — Walk to Mordor" } %>

<div class="min-h-screen bg-stone-900 text-gray-200 py-10 px-4">
  <div class="max-w-3xl mx-auto bg-stone-800 rounded-lg shadow-2xl border-4 border-yellow-600 p-8">
